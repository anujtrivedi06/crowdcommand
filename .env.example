# CrowdCommand Environment Variables
# Copy this file to functions/.env and fill in your values

# Google Cloud / Firebase
GOOGLE_CLOUD_PROJECT=your-project-id
FIREBASE_PROJECT_ID=your-firebase-project-id
VERTEX_AI_LOCATION=us-central1

# AI Models
GEMINI_MODEL=gemini-1.5-flash

# APIs
GOOGLE_MAPS_API_KEY=AIzaSyAxy57sa7xTxp-edhpL34FzaKVPSfJ65O8
FCM_SERVER_KEY=not-required-using-v1
WEATHER_API_KEY=your-weather-api-key

# Feature flags
USE_MOCK_VISION=true
DEMO_MODE=true

# Stadium configuration
STADIUM_NAME=M. Chinnaswamy Stadium
STADIUM_CAPACITY=35000
STADIUM_ZONES=12
STADIUM_LAT=12.9792
STADIUM_LNG=77.5994

# SOS cluster detection thresholds
SOS_CLUSTER_THRESHOLD=3
SOS_CLUSTER_WINDOW_MINUTES=2
SOS_CLUSTER_RADIUS_METRES=50

# Surge detection thresholds
SURGE_RATE_THRESHOLD=4
GATE_CAPACITY_THRESHOLD=80

# Wave exit staggering delays (minutes)
WAVE_2_DELAY_MINUTES=4
WAVE_3_DELAY_MINUTES=8
